// docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String
  price       Float
  currency    String   @default("EUR")
  stock       Int      @default(0)
  sku         String   @unique
  category    String
  brand       String
  images      Json     // { main: string, gallery: string[] }
  specs       Json     // Record<string, string | number | boolean>
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relation self many-to-many : produits similaires.
  // Prisma crée une table de jointure implicite `_SimilarProducts`.
  // La relation est stockée dans un seul sens ; on lit les deux côtés
  // (`similar` + `similarOf`) au repository pour la rendre symétrique.
  similar   Product[] @relation("SimilarProducts")
  similarOf Product[] @relation("SimilarProducts")

  cartItems CartItem[]
}

model Cart {
  id        String     @id @default(cuid())
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model CartItem {
  id        String   @id @default(cuid())
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  cartId    String
  product   Product  @relation(fields: [productId], references: [id])
  productId String
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Un produit n'apparaît qu'une fois par panier (on incrémente la quantité).
  @@unique([cartId, productId])
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String // hash (jamais le mot de passe en clair)
  name      String? // sert à dériver le trigramme affiché dans le header
  // SQLite ne supporte pas les enums Prisma : role est un String.
  // Valeurs attendues : "user" | "admin" (affectation admin via Prisma Studio).
  role      String   @default("user")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}